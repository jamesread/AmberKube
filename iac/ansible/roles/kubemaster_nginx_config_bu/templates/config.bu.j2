# Generated by Ansible (role kubemaster_nginx_config_bu){% if ansible_date_time is defined %} on {{ ansible_date_time.iso8601 }}{% endif %}
# Fetch: http://{{ ansible_host | default(inventory_hostname) }}/{{ config_bu_filename }}
# Ignition: http://{{ ansible_host | default(inventory_hostname) }}/{{ config_ign_filename }} (generated on kubemaster by role)
{% set _pk = (butane_ssh_authorized_key | default('', true)) or (ssh_authorized_key | default('', true)) %}
{% set _js = kubeadm_join_server | default('', true) %}
{% set _jt = kubeadm_join_token | default('', true) %}
{% set _ca = kubeadm_join_discovery_token_ca_cert_hash | default('', true) %}
{% if _ca | length > 0 and not _ca.startswith('sha256:') %}
{% set _join_hash = 'sha256:' ~ _ca %}
{% else %}
{% set _join_hash = _ca %}
{% endif %}
{% set _join_ok = (_js | length > 0) and (_jt | length > 0) and (_join_hash | length > 0) %}
variant: {{ butane_variant }}
version: {{ butane_version }}
passwd:
  users:
    - name: core
{% if _pk | length > 0 %}
      ssh_authorized_keys:
        - {{ _pk | to_json }}
{% endif %}
{% if _join_ok %}
systemd:
  units:
    - name: kubeadm-join.service
      enabled: true
      contents: |
        [Unit]
        Description=Kubernetes kubeadm join (oneshot)
        After=network-online.target
        Wants=network-online.target

        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStart=/usr/bin/kubeadm join {{ _js }} --token {{ _jt }} --discovery-token-ca-cert-hash {{ _join_hash }}

        [Install]
        WantedBy=multi-user.target
{% endif %}
